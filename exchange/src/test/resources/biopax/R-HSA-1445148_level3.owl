    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Barr, Francis A</bp:author>
    <bp:source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">J. Cell Biol. 191:367-81</bp:source>
