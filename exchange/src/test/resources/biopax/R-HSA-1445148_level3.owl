  <bp:Protein rdf:ID="Protein6">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IRAP</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LNPEP</bp:name>
